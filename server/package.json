{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run db:generate && rm -f tsconfig.tsbuildinfo && rm -rf dist && tsc && mkdir -p dist/generated && cp -r src/generated/prisma dist/generated/prisma",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "create:admin": "tsx scripts/create-admin.ts",
    "migrate:csv-users": "tsx scripts/migrate-users.ts",
    "migrate:csv-categories": "tsx scripts/migrate-categories.ts",
    "migrate:csv-authors": "tsx scripts/migrate-authors.ts",
    "migrate:csv-publishers": "tsx scripts/migrate-publishers.ts",
    "migrate:csv-narrators": "tsx scripts/migrate-narrators.ts",
    "migrate:csv-books": "tsx scripts/migrate-books.ts",
    "migrate:csv-payment-gateways": "tsx scripts/migrate-payment-gateways.ts",
    "migrate:csv-role-permissions": "tsx scripts/migrate-role-permissions.ts",
    "migrate:csv-shipping-methods": "tsx scripts/migrate-shipping-methods.ts",
    "migrate:csv-default-revenue-rules": "tsx scripts/migrate-default-revenue-rules.ts",
    "migrate:csv-all": "npm run migrate:csv-users && npm run migrate:csv-categories && npm run migrate:csv-authors && npm run migrate:csv-publishers && npm run migrate:csv-narrators && npm run migrate:csv-books && npm run migrate:csv-payment-gateways && npm run migrate:csv-role-permissions && npm run migrate:csv-shipping-methods && npm run migrate:csv-default-revenue-rules",
    "clean:orders": "tsx scripts/clean-orders.ts",
    "seed:defaults": "prisma db seed",
    "seed:legacy": "npm run migrate:csv-all",
    "seed:all": "npm run seed:defaults && npm run seed:legacy"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@prisma/adapter-pg": "^6.19.3",
    "@trpc/server": "^11.0.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "uuid": "^14.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
