  full_name               String?
  genre                   String?
  instagram_url           String?
  is_active               Boolean  @default(true)
  phone                   String?
  portfolio_url           String?
  preferred_language      String?
  referral_code           String?  @unique
  referred_by             String?
  specialty               String?
