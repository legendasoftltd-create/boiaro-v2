DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_USE_RANDOM_64_CHAR_HEX"
JWT_REFRESH_SECRET="CHANGE_ME_USE_ANOTHER_RANDOM_64_CHAR_HEX"
GOOGLE_CLIENT_ID="YOUR_GOOGLE_WEB_CLIENT_ID"

PORT=3001

# Comma-separated origins (when API is on a different domain than frontend)
CORS_ORIGIN="https://yourdomain.com"
# Public frontend origin (used for payment callback redirects)
FRONTEND_URL="https://staging.boiaro.com"
# Public API origin (used for SSLCommerz callback endpoints)
BACKEND_URL="https://staging.boiaro.com"

NODE_ENV=production
