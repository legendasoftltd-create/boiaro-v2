DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_USE_RANDOM_64_CHAR_HEX"
JWT_REFRESH_SECRET="CHANGE_ME_USE_ANOTHER_RANDOM_64_CHAR_HEX"
GOOGLE_CLIENT_ID="YOUR_GOOGLE_WEB_CLIENT_ID"
FACEBOOK_APP_ID="YOUR_FACEBOOK_APP_ID"
FACEBOOK_APP_SECRET="YOUR_FACEBOOK_APP_SECRET"

PORT=3001

# Comma-separated origins (when API is on a different domain than frontend)
CORS_ORIGIN="https://yourdomain.com"
# Public frontend origin (used for payment callback redirects)
FRONTEND_URL="https://staging.boiaro.com"
# Public API origin (used for SSLCommerz callback endpoints)
BACKEND_URL="https://staging.boiaro.com"

NODE_ENV=production


# ── Amazon S3 Storage ─────────────────────────────────────────────────────────
# Set all three required vars to enable S3. Without them the server falls back
# to local disk storage (uploads/ folder) — safe for development.
#
# Required:
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_S3_BUCKET="your-s3-bucket-name"
#
# Optional:
AWS_REGION="us-east-1"                         # default: us-east-1
# AWS_S3_ENDPOINT="https://..."                # S3-compatible endpoint (MinIO / Cloudflare R2)
# AWS_S3_PUBLIC_URL="https://cdn.yourdomain.com" # CDN / custom domain for public file URLs
#
# S3 bucket folder layout (created automatically):
#   covers/    — book cover images
#   ebooks/    — EPUB and PDF files
#   audio/     — audiobook MP3 / WAV / AAC files
#   avatars/   — user, author, narrator profile photos
#   images/    — site banners, blog covers, ad images
#   misc/      — anything else